# ==== Acceso admin ====
# Código para entrar al panel /admin (cámbialo en producción)
ADMIN_CODE=met-admin-2026

# ==== Firma de sesiones / pase de acceso ====
# Secreto para firmar cookies (sesión admin y pase de pago).
# Genera uno propio:
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
ACCESS_SECRET=cambia-esto-por-un-secreto-largo-y-aleatorio

# ==== URL base (redirecciones de pago) ====
NEXT_PUBLIC_BASE_URL=http://localhost:3000

# ==== Pago con IziPay (micuentaweb.pe) ====
# Credenciales desde el panel de IziPay → Configuración → Claves de API REST
IZIPAY_SHOP_ID=
IZIPAY_API_KEY=
IZIPAY_PUBLIC_KEY=
# Clave "HMAC-SHA-256" del panel de IziPay. OBLIGATORIA para verificar que el
# pago es real antes de dar acceso (sin ella, el pago no se puede confirmar).
IZIPAY_HASH_KEY=

# Monto y moneda del acceso al examen
PAY_AMOUNT=15
PAY_CURRENCY=USD

# ==== Corrección de Writing ====
# Endpoint de LanguageTool (por defecto usa la API pública si se deja vacío)
LANGUAGETOOL_API=https://api.languagetool.org/v2/check
